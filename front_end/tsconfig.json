{
  "extends": "../config/typescript/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "ignored",
    "rootDir": ".",
    "target": "ES2023",
    "lib": [
      "ES2023",
      "ES2024.Promise",
      "ESNext.Iterator",
      "ESNext.Collection",
      "ESNext.Array",
      "dom",
      "dom.iterable",
      "webworker",
      "webworker.iterable"
    ],
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "rules": {
          "no-complex-attribute-binding": "off",
          "no-noncallable-event-binding": "off",
          "no-missing-import": "error",
          "no-unknown-tag-name": "error",
          "no-unclosed-tag": "error"
        }
      }
    ],
    "types": ["mocha"]
  },
  "exclude": [
    "devtools_compatibility.js",
    "Images/generate-css-vars.js",
    "core/i18n/collect-ui-strings.js",
    "core/i18n/generate-locales-js.js",
    "panels/timeline/enable-easter-egg.js"
  ],
  "references": [{ "path": "./tsconfig.compatibility.json" }]
}
